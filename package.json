{
  "name": "hansel-mejarito-portfolio",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:clean": "rm -rf .next && bash ./scripts/dev.sh",
    "build": "bash ./scripts/build.sh",
    "start": "bash -c 'source ~/.nvm/nvm.sh 2>/dev/null; node ./node_modules/next/dist/bin/next start'",
